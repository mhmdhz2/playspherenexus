// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() { return isAuth() && getUserRole() == 'admin'; }
    function isStaff() { return isAuth() && (getUserRole() == 'staff' || getUserRole() == 'admin'); }
    function isVendor() { return isAuth() && getUserRole() == 'vendor'; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }

    // USERS: own profile readable/writable; admin can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Children subcollection
      match /children/{childId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Points history subcollection
      match /pointsHistory/{pointId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuth();
      }
    }

    // BOOKINGS: user can read own bookings; admin/staff can read all
    match /bookings/{bookingId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin() || isStaff()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    // ZONES: anyone authenticated can read; only admin/staff can write
    match /zones/{zoneId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isStaff();
    }

    // EVENTS: anyone authenticated can read; only admin can create/update
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // EVENT RESERVATIONS
    match /eventReservations/{resId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // VENDORS: anyone authenticated can read; only admin can create vendors
    match /vendors/{vendorId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      // Menu items: vendor who owns it or admin can write
      match /menu/{itemId} {
        allow read: if isAuth();
        allow write: if isAdmin() || isVendor();
      }
    }

    // ORDERS: user can read own orders; vendor/admin can read all
    match /orders/{orderId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin() || isVendor()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isVendor();
    }

    // LOST & FOUND: user can submit and read own; admin/staff can read/update all
    match /lostFound/{itemId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin() || isStaff()
      );
      allow create: if isAuth();
      allow update: if isAdmin() || isStaff();
    }

    // SUPPORT TICKETS
    match /supportTickets/{ticketId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin() || isStaff()
      );
      allow create: if isAuth();
      allow update: if isAdmin() || isStaff();
    }

    // JOB LISTINGS: anyone can read; only admin/vendor can create
    match /jobs/{jobId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isVendor();
      allow update, delete: if isAdmin();

      // Applications
      match /applications/{appId} {
        allow read: if isAdmin() || isVendor();
        allow create: if isAuth();
      }
    }
  }
}
